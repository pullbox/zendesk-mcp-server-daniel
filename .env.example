ZENDESK_SUBDOMAIN=xxx
ZENDESK_EMAIL=xxx
ZENDESK_API_KEY=xxx

# Optional — enables AI-generated ticket summaries using Claude Haiku (console.anthropic.com)
# Without this, summaries use flag-based text with 500-char comment snippets
ANTHROPIC_API_KEY=

# Optional — base directory for saving downloaded ticket attachments
# Files are saved to <ATTACHMENT_SAVE_DIR>/<ticket_id>/<filename>
# Defaults to ~/Downloads/<ticket_id>/<filename> if not set
ATTACHMENT_SAVE_DIR=
